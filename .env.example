DISCORD_TOKEN=your-bot-token
DB_PATH=/app/data/bot.sqlite
COGS=girldle

# Optional. Set on the operator's bot only. When set, the girldle_admin cog
# (if listed in COGS) registers owner-only commands as guild-restricted to
# this guild, so they don't leak into autocomplete on any other server.
# OWNER_GUILD_ID=000000000000000000
